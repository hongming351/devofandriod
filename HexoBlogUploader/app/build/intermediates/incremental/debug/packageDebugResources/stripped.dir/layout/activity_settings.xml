<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- 工具栏 -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:title="设置"
        app:titleTextColor="@android:color/white" />

    <!-- 滚动视图 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- GitHub设置 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GitHub 设置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GitHub 用户名"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/editGithubUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="输入GitHub用户名"
                android:inputType="text"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GitHub Token (可选)"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/editGithubToken"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="输入GitHub Personal Access Token"
                android:inputType="textPassword"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="仓库地址"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/editRepoUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="https://github.com/username/repo.git"
                android:inputType="textUri"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/buttonSaveGithub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="保存 GitHub 设置"
                android:backgroundTint="@color/primary"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"
                android:padding="12dp" />

            <!-- 博客设置 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="博客设置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="博客标题"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/editBlogTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="输入博客标题"
                android:inputType="text"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="作者名称"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="12dp" />

            <EditText
                android:id="@+id/editAuthorName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="输入作者名称"
                android:inputType="text"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/buttonSaveBlog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="保存博客设置"
                android:backgroundTint="@color/primary"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"
                android:padding="12dp" />

            <!-- 存储设置 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="存储设置"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="博客存储路径"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/editStoragePath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="/storage/emulated/0/HexoBlog"
                android:inputType="text"
                android:background="@android:drawable/edit_text"
                android:padding="12dp"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/buttonSaveStorage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="保存存储设置"
                android:backgroundTint="@color/primary"
                android:textColor="@android:color/white"
                android:layout_marginTop="16dp"
                android:padding="12dp" />

            <!-- 关于应用 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="关于应用"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/buttonCheckUpdates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="检查更新"
                android:backgroundTint="@color/secondary"
                android:textColor="@android:color/white"
                android:layout_marginTop="8dp"
                android:padding="12dp" />

            <Button
                android:id="@+id/buttonFeedback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="反馈建议"
                android:backgroundTint="@color/secondary"
                android:textColor="@android:color/white"
                android:layout_marginTop="8dp"
                android:padding="12dp" />

            <Button
                android:id="@+id/buttonAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="关于"
                android:backgroundTint="@color/secondary"
                android:textColor="@android:color/white"
                android:layout_marginTop="8dp"
                android:padding="12dp" />

            <!-- 版本信息 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="版本 1.0.0"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>